# Discord bot token — get one at https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# The ID of the Discord channel where restock alerts will be posted
# Right-click a channel in Discord (with Developer Mode on) → Copy Channel ID
DISCORD_CHANNEL_ID=your-channel-id-here

# The ID of your Discord server (guild)
# Right-click the server name in Discord (with Developer Mode on) → Copy Server ID
DISCORD_GUILD_ID=your-guild-id-here

# (Optional) Override the URL to monitor — defaults to DAC restocks page
# CHECK_URL=https://www.diamondartclub.com/collections/diamond-painting-restocks
