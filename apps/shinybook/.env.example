# Local Expo dev — copy to `.env` and fill in from `sst output --stage dev`.
# When the site is built via SST's StaticSite, these values are injected at
# build time from the deployed stack outputs (see sst.config.ts).
# Only EXPO_PUBLIC_* vars are exposed to client bundles.

EXPO_PUBLIC_API_URL=https://api.allurien.dev
EXPO_PUBLIC_USER_POOL_ID=us-east-1_XXXXXXXXX
EXPO_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_COGNITO_DOMAIN=shinybook-dev.auth.us-east-1.amazoncognito.com
EXPO_PUBLIC_PHOTOS_BUCKET=shinybook-dev-photosbucket-xxxxxxxx
